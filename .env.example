# Jubidate AI — Environment Variables
# Copy this file to .env and fill in your keys.
# At least ONE provider key is required to run the platform.
#
# ─────────────────────────────────────────────
#  FREE TIERS (no credit card required)
# ─────────────────────────────────────────────

# Google AI Studio — aistudio.google.com
# Free models: Gemini 2.0 Flash, Gemini 2.5 Flash, Gemini 2.5 Flash-Lite
GOOGLE_API_KEY=

# Groq — console.groq.com
# Free models: Llama 3.1 8B Instant, Llama 3.3 70B Versatile
GROQ_API_KEY=

# OpenRouter — openrouter.ai
# Free models (no credits needed): DeepSeek R1, QwQ 32B, Llama 3.1 8B,
#   Gemma 3 27B, Qwen 3 14B  (all :free tier models)
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────
#  PAID PROVIDERS (optional)
# ─────────────────────────────────────────────

# OpenAI — platform.openai.com
OPENAI_API_KEY=

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# Moonshot (Kimi) — platform.moonshot.cn
MOONSHOT_API_KEY=

# MiniMax — platform.minimaxi.com (via Fireworks)
MINIMAX_API_KEY=

# Fireworks AI — fireworks.ai
FIREWORKS_API_KEY=

# ─────────────────────────────────────────────
#  OPTIONAL SETTINGS
# ─────────────────────────────────────────────

# Debate rounds per session (default: 2, range: 1-6)
# DEBATE_ROUNDS=2

# LiteLLM request timeout in seconds (default: 120)
# LITELLM_TIMEOUT_SECONDS=120

# Enable mock LLM responses for offline testing
# MOCK_LLM_RESPONSES=false
