# Yojaka Backend — Environment Variables
# Copy to .env and fill in your values.

YOJAKA_DEPLOYMENT=dev                   # dev | prod

# Database
DATABASE_URL=sqlite+aiosqlite:///./yojaka.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/yojaka  # prod

# Session budget
SESSION_TOKEN_BUDGET=40000
MAX_AGENT_OUTPUT_TOKENS=400
CONTEXT_WINDOW_TURNS=6

# Provider API keys (omit to disable that provider)
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
FIREWORKS_API_KEY=

# Defaults
DEFAULT_MODEL=gemini-2.0-flash
ENABLE_MOCK_PROVIDER=true

# Per-client session cap
MAX_SESSIONS_PER_CLIENT=10

# Production only
REDIS_URL=
PROMETHEUS_ENABLED=false
